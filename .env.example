ELEVENLABS_API_KEY=your_api_key_here
AGENT_ID=your_agent_id_here
CORS_ORIGINS=http://localhost:3000

# PostgreSQL - obrigatório para persistir leads (asyncpg + Alembic)
# Produção (Coolify): use a connection string INTERNA (rede Docker, sem porta pública),
# com usuário de aplicação dedicado (lumi_app), nunca o superuser postgres.
# Dev local (docker-compose.yml): aponta para a porta 5433 do host (a 5432 está em uso).
DATABASE_URL=postgresql://lumi_app:lumi_dev_password@localhost:5433/lumi

# Credenciais do Postgres do docker-compose.yml (usadas só no dev local).
# Em produção o Coolify gerencia essas credenciais por fora.
POSTGRES_USER=lumi_app
POSTGRES_PASSWORD=lumi_dev_password
POSTGRES_DB=lumi

# Chave de administração - protege GET /api/leads/list e PATCH /api/leads/{id}/contato-feito
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your_admin_key_here

# Twilio - dashboard de uso e custo (GET /api/usage/twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# SMTP - envia um e-mail de notificação a cada novo lead registrado.
# A notificação só dispara quando SMTP_HOST e LEAD_NOTIFICATION_EMAIL estão definidos.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
SMTP_FROM=seu_email@gmail.com
SMTP_USE_TLS=true
# Destinatário que recebe o aviso de novo lead
LEAD_NOTIFICATION_EMAIL=contato@empresa.com
